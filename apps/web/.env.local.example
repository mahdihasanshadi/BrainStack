# Base URL of the BrainStack API (includes /api global prefix in route paths)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# CORS: apps/api FRONTEND_URL must match this app's dev origin exactly.
# Default Next.js dev server: http://localhost:3000
# Set FRONTEND_URL=http://localhost:3000 in apps/api/.env

# Homepage hero introductory video (YouTube embed URL, youtu.be link, or direct .mp4 URL)
# NEXT_PUBLIC_HERO_INTRO_VIDEO_URL=https://www.youtube.com/embed/YOUR_VIDEO_ID?rel=0
# Optional poster image for MP4 before play (place file in apps/web/public/)
# NEXT_PUBLIC_HERO_INTRO_VIDEO_POSTER=/brand-video-poster.jpg

# Stripe publishable key for client-side Checkout / Elements
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
