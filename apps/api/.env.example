# HTTP server port (validated default: 3001)
PORT=3001

# PostgreSQL connection string used by TypeORM
DATABASE_URL=postgresql://brainstack:brainstack@localhost:5432/brainstack

# Secret for signing JWT access tokens (minimum 32 characters)
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# Token lifetime — duration suffix (15m, 7d) or seconds (3600)
JWT_EXPIRY=7d

# Redis connection URI for caching and sessions
REDIS_URL=redis://localhost:6379

# Default cache entry TTL in seconds when set() is called without an explicit ttl
REDIS_DEFAULT_TTL=3600

# Stripe secret API key (server-side only)
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key

# Stripe webhook signing secret from the Dashboard
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_signing_secret

# Public URL of the Next.js frontend (used for CORS)
FRONTEND_URL=http://localhost:3000

# Outbound SMTP relay for transactional email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=replace_with_smtp_password
SMTP_FROM=BrainStack <noreply@example.com>
